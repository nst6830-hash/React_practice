//ThemmodProvider.jsx

import React, { createContext, useState } from 'react'

// Context 생성
// 전역으로 공유할 데이터를 담는 "통로" 역할
export const ThemmodContext = createContext()

// Provider 컴포넌트
// children으로 감싼 컴포넌트들에게 데이터를 전달
export const ThemmodProvider = (props) => {

    // 다크모드 상태
    const [dark,setDark] = useState(true)

    // 다크모드 상태 변경 함수
    const toggle = () => {
        setDark(!dark)
    }

    return (

        // Provider를 통해 value 전달
        // App 및 하위 컴포넌트에서 사용할 수 있음
        <ThemmodContext.Provider value={{dark,toggle}}>

            {/* Provider로 감싼 컴포넌트(App)가 들어오는 자리 */}
            {props.children}

        </ThemmodContext.Provider>
    )
}


