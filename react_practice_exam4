//App.jsx

import React, { useContext, useState } from 'react'

// Context 가져오기
import { ThemmodContext } from './ThemmodProvider'

const App = () => {

  // 숫자 입력값 상태
  const [num,setNum] = useState('')

  // Context에서 dark 상태와 toggle 함수 가져오기
  const {dark,toggle} = useContext(ThemmodContext)

  return (
    <div>

      {/* 숫자 입력 */}
      <input
        type='text'
        onChange={(e)=>setNum(e.target.value)}
      ></input>

      {/* 입력된 숫자가 10보다 큰지 조건 출력 */}
      <p>
        {num > 10 ?  "10보다 큽니다" : "10보다 작습니다."}
      </p>

      {/* 다크모드 상태 변경 버튼 */}
      <button onClick={()=>toggle()}>
        모드
      </button>

      {/* 현재 모드 상태 출력 */}
      {dark ? '다크': '라이트'}

    </div>
  )
}

export default App

export default App
