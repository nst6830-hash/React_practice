import React, { useCallback, useState } from 'react'
import {Child1} from './components/Child1'
import Child4 from './components/Child4'
import { Child3 } from './components/Child3';

const App = () => {

  const [num,setNum]=useState(0)

  const increase = () => {
    debugger;
    setNum(num+1)
  }

  const onClickReset = useCallback(()=>{
    setNum(0)
  },[])

  return (
    <div>

      {/* 1증가 버튼 만들어 1씩 증가시켜 num 출력 */}
      <button onClick={increase}>1증가 버튼</button>

      <p>{num}</p>

      <Child1 onClickReset={onClickReset}/>

      {/* App 렌더링 될 때마다 onClickReset 함수는 새로 생성됨
      React.memo는 props가 변경되었다고 판단하여 재렌더링 수행 */}
    {/* useCallback은 onClickReset 처음 한번만 생성되고 재사용됨 -> 동일한 참조값으로 인식 */}
    {/* App 렌더링 될 때 마다 같은 참조 값을 가진 주소로 인식 -> Child1에서 렌더링 방지됨  */}
    {/* Child1의 자식들은 Child2,Child3 도 방지됨 */}
      <Child4/>

    </div>
  )
}

export default App
