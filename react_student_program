import React from 'react'

const StudentList = ({students,onEdit,onDelete}) => {

  return (
    <div>

        <ul>

            {/* 학생 목록 렌더링 */}
            {students.map((stu)=> (

                <li key={stu.id}>

                    {/* 학생 정보 출력 */}
                    {stu.name} | {stu.age} | {stu.major}

                    {/* 수정 버튼 */}
                    <button onClick={()=>onEdit(stu)}>
                      수정
                    </button>

                    {/* 삭제 버튼 */}
                    <button onClick={()=>onDelete(stu.id)}>
                      삭제
                    </button>

                </li>

            ))}

        </ul>

    </div>
  )
}

export default StudentList
