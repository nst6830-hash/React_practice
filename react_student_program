import React, { useEffect, useState } from 'react'

const StudentForm = ({onSubmit,selected}) => {

    // 학생 입력 상태
    const [student,setStudent]=useState({name :'',age:'',major:''})

    // selected 변경 시 폼 데이터 갱신
    // 수정 모드 → 기존 데이터
    // 추가 모드 → 빈값
    useEffect(()=>{
       setStudent(selected || ({name :'',age:'',major:''}))
    },[selected])

    const handleChange = (e) => {

        const {name,value} = e.target // input 값

        setStudent((stu)=> ({
            ...stu, // 기존 객체 복사
            [name]:value // name 속성 값 변경
        }))
    }

    const handleSubmit =(e) =>{
        e.preventDefault()

        if(!student.name){
            return
        }

        // 부모 컴포넌트(App)로 학생 데이터 전달
        onSubmit(student)

        // 입력창 초기화
        setStudent({name:'', age:'', major:''})
    }

  return (
    <div>
        <form onSubmit={handleSubmit}>

            <input
            placeholder='이름'
            value={student.name}
            name='name'
            onChange={handleChange}
            />

            <input
            placeholder='나이'
            value={student.age}
            name='age'
            onChange={handleChange}
            />

            <input
            placeholder='전공'
            value={student.major}
            name='major'
            onChange={handleChange}
            />

            {/* id 존재 → 수정 / 없으면 → 추가 */}
            <button type='submit'>
              {student.id ? '수정':'추가'}
            </button>

        </form>
    </div>
  )
}

export default StudentForm

