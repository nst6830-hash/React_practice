import React, { useEffect, useState } from 'react'

const App = () => {

  const [name,setName]=useState('')

  const onName = (e) => {
    setName(e.target.value)
  }

  useEffect(() => {
    alert("컴포넌트가 마운트됨")
    
  },[])

  useEffect(() => {
    console.log('이름이변경되었습니다:' + [name]); 
  },[name])

  return (
    <div>
      <div>
        <input onChange={onName} value={name} />
      <div>이름 : {name}</div>
      </div>
    </div>
  )
}

export default App
